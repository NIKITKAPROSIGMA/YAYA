        isDashing = true
        active.skillActive = true
        forceFOV(DASH_FOV, DASH_DURATION + 0.2)
        
        local s = Instance.new("Sound", root)
        s.SoundId = SOUND_ID
        s.Volume = 2
        s:Play()
        Debris:AddItem(s,2)
        
        local anim = Instance.new("Animation")
        anim.AnimationId = ANIM_ID
        local track = hum:LoadAnimation(anim)
        track.Priority = Enum.AnimationPriority.Action4
        track:Play()
        
        local att = Instance.new("Attachment", root)
        local e = ELEC_PATH:Clone()
        e.Parent = att
        for _, v in pairs(att:GetDescendants()) do
            if v:IsA("ParticleEmitter") then
                v.LightInfluence = 0
                v.LockedToPart = true
                v.Color = ColorSequence.new(COLOR_BLUE)
                v:Emit(70)
                local kps = {}
                for _, kp in ipairs(v.Size.Keypoints) do
                    table.insert(kps, NumberSequenceKeypoint.new(kp.Time, kp.Value * 0.4))
                end
                v.Size = NumberSequence.new(kps)
                task.delay(0.3, function() v.Enabled = false end)
            end
        end
        Debris:AddItem(att,1.2)
        
        local look = Camera.CFrame.LookVector
        local dashDir = (Vector3.new(look.X, 0, look.Z)).Unit
        if look.X == 0 and look.Z == 0 then dashDir = root.CFrame.LookVector end
        root.CFrame = CFrame.new(root.Position, root.Position + dashDir)
        
        local isStickInvisible = active.handMesh and active.handMesh.Transparency == 1
        -- уменьшаем скорость в visible моде с 125 до 123 (примерно 1.5%)
        local dashSpeed = isStickInvisible and 75 or 123
        
        local startTime = tick()
        local lastImage = 0
        local dashConn
        dashConn = RunService.Heartbeat:Connect(function()
            if tick() - startTime < DASH_DURATION and character and character.Parent then
                root.AssemblyLinearVelocity = dashDir * dashSpeed + Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
                root.CFrame = CFrame.new(root.Position, root.Position + dashDir)
                if tick() - lastImage > 0.05 then
                    createAfterImage(character)
                    lastImage = tick()
                end
            else
                dashConn:Disconnect()
                track:Stop(0.1)
                track:Destroy()
                isDashing = false
                active.skillActive = false
                updateFOVByStickVisibility()
            end
        end)
    end
    
    local function useSkill()
        if not active.fullModActive then return end
        local isStickInvisible = active.handMesh and active.handMesh.Transparency == 1
        if isStickInvisible then
            if canUseSkill() then
                applyDash()
            end
        else
            if currentStacks > 0 and canUseSkill() then
                currentStacks = currentStacks - 1
                if currentStacks == MAX_STACKS - 1 then lastStackRegen = tick() end
                applyDash()
            end
        end
    end
    
    local main = pgui:FindFirstChild("Main")
    if not main then return end
    local moveset = main:FindFirstChild("Moveset", true)
    if not moveset then return end
    local original = moveset:FindFirstChild("Garuda Rebound")
    if not original then return end
    
    if moveset:FindFirstChild("ElectricStep_Skill") then
        moveset.ElectricStep_Skill:Destroy()
    end
    
    local clone = original:Clone()
    clone.Name = "ElectricStep_Skill"
    clone.LayoutOrder = -1000
    local itemName = clone:WaitForChild("ItemName")
    local keyContainer = clone:FindFirstChild("Key")
    local keyText = nil
    if keyContainer then
        if keyContainer:IsA("TextLabel") or keyContainer:IsA("TextButton") then
            keyText = keyContainer
        else
            keyText = keyContainer:FindFirstChildWhichIsA("TextLabel") or keyContainer:FindFirstChildWhichIsA("TextButton")
        end
    end
    if clone:FindFirstChild("Tip") then clone.Tip:Destroy() end
    
    local function forceText()
        local isStickInvisible = active.handMesh and active.handMesh.Transparency == 1
        if isStickInvisible then
            if itemName.Text ~= SKILL_NAME then itemName.Text = SKILL_NAME end
        else
            local txt = string.format("%s %d/%d", SKILL_NAME, currentStacks, MAX_STACKS)
            if itemName.Text ~= txt then itemName.Text = txt end
        end
        if keyText and keyText.Text ~= "Z" then
            keyText.Text = "Z"
        end
    end
    
    itemName:GetPropertyChangedSignal("Text"):Connect(forceText)
    forceText()
    
    for _, s in ipairs(clone:GetDescendants()) do
        if s:IsA("LocalScript") then s.Disabled = true end
    end
    clone.Parent = moveset
    
    local bar = clone:FindFirstChild("Cooldown", true) or clone:FindFirstChild("Progress", true)
    local cooldownLoop = RunService.Heartbeat:Connect(function()
        if not clone or not clone.Parent then return end
        local isStickInvisible = active.handMesh and active.handMesh.Transparency == 1
        if isStickInvisible then
            if bar then bar.Visible = false end
        else
            if currentStacks < MAX_STACKS then
                local elapsed = tick() - lastStackRegen
                if elapsed >= STACK_COOLDOWN then
                    currentStacks = math.min(currentStacks + 1, MAX_STACKS)
                    lastStackRegen = tick()
                end
                if bar then
                    bar.Visible = true
                    bar.Size = UDim2.new(1, 0, math.clamp(1 - (elapsed / STACK_COOLDOWN), 0, 1), 0)
                end
            elseif bar then
                bar.Visible = false
            end
        end
        forceText()
    end)
    
    local clickConn = itemName.MouseButton1Click:Connect(useSkill)
    local inputConn = UserInputService.InputBegan:Connect(function(i, g)
        if not g and i.KeyCode == Enum.KeyCode.Z then useSkill() end
    end)
    
    active.electricStepCleanup = function()
        if clickConn then clickConn:Disconnect() end
        if inputConn then inputConn:Disconnect() end
        if cooldownLoop then cooldownLoop:Disconnect() end
        if clone then clone:Destroy() end
        isDashing = false
        active.skillActive = false
        active.fovForced = false
        updateFOVByStickVisibility()
    end
end

local function resetUIToDefault()
    local main = pgui:FindFirstChild("Main")
    if not main then return end
    local ultFrame = main:FindFirstChild("Ultimate", true)
    if ultFrame then
        local bar = ultFrame:FindFirstChild("Bar", true)
        if bar then
            local touch = bar:FindFirstChild("Touch", true); if touch then touch.Active = true; touch.Visible = true end
            local readyLabel = bar:FindFirstChild("Ready", true) and bar.Ready:FindFirstChild("Ready", true); if readyLabel then readyLabel.Text = "Press G To Activate" end
        end
    end
    ContextActionService:UnbindAction("Lightning_InputLock")
    for obj, color in pairs(active.originalColors) do
        if obj and obj.Parent then
            if obj:IsA("UIGradient") then obj.Color = color
            elseif obj:IsA("ImageLabel") then obj.ImageColor3 = color
            else obj.BackgroundColor3 = color end
        end
    end
    active.originalColors = {}
end

local function changeUltColors()
    local main = pgui:FindFirstChild("Main")
    if not main then return false end
    local ultFrame = main:FindFirstChild("Ultimate", true)
    if not ultFrame then return false end
    local function recolor(parent, color, save)
        if not parent then return end
        for _, child in ipairs(parent:GetDescendants()) do
            local name = child.Name:lower()
            if name:find("fill") or name:find("progress") then
                if child:IsA("Frame") or child:IsA("ImageLabel") or child:IsA("UIGradient") then
                    if save and not active.originalColors[child] then
                        if child:IsA("UIGradient") then active.originalColors[child] = child.Color
                        elseif child:IsA("ImageLabel") then active.originalColors[child] = child.ImageColor3
                        else active.originalColors[child] = child.BackgroundColor3 end
                    end
                    if child:IsA("UIGradient") then child.Color = ColorSequence.new(color)
                    elseif child:IsA("ImageLabel") then child.ImageColor3 = color
                    else child.BackgroundColor3 = color end
                end
            end
        end
    end
    local bar = ultFrame:FindFirstChild("Bar", true); local special = ultFrame:FindFirstChild("Special", true)
    if not bar and not special then return false end
    recolor(bar, ULT_CONFIG.LightningColor, true); recolor(special, ULT_CONFIG.LightningColor, true)
    return true
end

local function blockGandTouch()
    local main = pgui:FindFirstChild("Main")
    if not main then return false end
    local ultFrame = main:FindFirstChild("Ultimate", true)
    if not ultFrame then return false end
    local bar = ultFrame:FindFirstChild("Bar", true)
    if not bar then return false end
    local touch = bar:FindFirstChild("Touch", true); if touch then touch.Active = false; touch.Visible = false end
    local readyLabel = bar:FindFirstChild("Ready", true) and bar.Ready:FindFirstChild("Ready", true); if readyLabel then readyLabel.Text = "..." end
    ContextActionService:BindActionAtPriority("Lightning_InputLock", function() return Enum.ContextActionResult.Sink end, false, 3000, Enum.KeyCode.G)
    return true
end

local function checkSkillsAndUlt()
    local main = pgui:FindFirstChild("Main")
    if not main then return false end
    local moveset = main:FindFirstChild("Moveset", true)
    if not moveset then return false end
    for original, new in pairs(ULT_CONFIG.MovesMap) do
        local item = moveset:FindFirstChild(original); local label = item and item:FindFirstChild("ItemName")
        if not label then return false end
        if label.Text ~= new then label.Text = new; if label.Text ~= new then return false end end
    end
    local ultFrame = main:FindFirstChild("Ultimate", true)
    if not ultFrame then return false end
    local title = ultFrame:FindFirstChild("Title", true)
    if not title then return false end
    if title.Text ~= ULT_CONFIG.NewUltTitle then title.Text = ULT_CONFIG.NewUltTitle; if title.Text ~= ULT_CONFIG.NewUltTitle then return false end end
    return true
end

local function setupHandMeshAndCombatTrail(char)
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
    if not hand then hand = char:WaitForChild("RightHand",2) or char:WaitForChild("Right Arm",2) end
    if not hand then return false end
    if hand:FindFirstChild("HandCustomMesh") then hand.HandCustomMesh:Destroy() end
    local part = Instance.new("Part", hand); part.Name = "HandCustomMesh"; part.CanCollide = false; part.Massless = true; part.Size = Vector3.new(1,1,1)
    active.handMesh = part
    local mesh = Instance.new("SpecialMesh", part); mesh.MeshId = GARUDA_CONFIG.MeshId; mesh.TextureId = GARUDA_CONFIG.TextureId; mesh.Scale = GARUDA_CONFIG.Scale
    local weld = Instance.new("Weld", part); weld.Part0 = hand; weld.Part1 = part; weld.C0 = CFrame.new(0,-1,0) * CFrame.Angles(math.rad(-45), math.rad(-90), 0)
    local effectsFolder = workspace:WaitForChild("Effects",5)
    if effectsFolder then
        if active.combatTrailConnection then active.combatTrailConnection:Disconnect() end
        active.combatTrailConnection = effectsFolder.ChildAdded:Connect(onCombatTrailAdded)
        for _, child in ipairs(effectsFolder:GetChildren()) do onCombatTrailAdded(child) end
    end
    return true
end

local function hideGarudaLoop(char)
    if active.garudaHideLoop then task.cancel(active.garudaHideLoop) end
    active.garudaHideLoop = task.spawn(function()
        while active.fullModActive and char and char.Parent do
            local garuda = findGarudaInCharacter(char); if garuda then forceHide(garuda) end
            task.wait(0.5)
        end
    end)
end

local function activateAllAfterValidation(char)
    local startTime = os.clock(); local timeout = 5; local skillsOk = false
    while os.clock() - startTime < timeout do if checkSkillsAndUlt() then skillsOk = true; break end; task.wait(0.1) end
    if not skillsOk then return false end
    if not changeUltColors() then return false end
    if not blockGandTouch() then return false end
    active.fullModActive = true
    if not setupHandMeshAndCombatTrail(char) then return false end
    setupAnimationReplacer(char)
    setupIdleBlock(char)
    hideGarudaLoop(char)
    startBallWatcher()
    startVisibilityUpdater()
    setupExtraEffects(char)
    setupBlinkEffects(char)
    setupExtraEffects4(char)
    setupElectricStep(char)

    -- Обработка двойного клика для Thunder Kick (Rising Rage)
    local main = pgui:FindFirstChild("Main")
    if main then
        local moveset = main:FindFirstChild("Moveset", true)
        if moveset then
            local risingRage = moveset:FindFirstChild("Rising Rage")
            if risingRage then
                local itemName = risingRage:FindFirstChild("ItemName")
                if itemName then
                    itemName.MouseButton1Click:Connect(function()
                        local now = tick()
                        if now - active.lastThunderKickTime < 0.3 then
                            active.thunderKickDoubleTap = true
                        else
                            active.thunderKickDoubleTap = false
                        end
                        active.lastThunderKickTime = now
                    end)
                end
            end
        end
    end

    return true
end

local function fullReset()
    active.fullModActive = false
    active.garudaActive = false
    active.ultActive = false
    active.skillActive = false
    active.fovForced = false
    active.thunderKickDoubleTap = false
    fullCleanupUlt()
    disableGaruda()
    if active.garudaHideLoop then task.cancel(active.garudaHideLoop); active.garudaHideLoop = nil end
    if active.visibilityUpdater then active.visibilityUpdater:Disconnect(); active.visibilityUpdater = nil end
    if active.combatTrailConnection then active.combatTrailConnection:Disconnect(); active.combatTrailConnection = nil end
    if active.extraEffectsCleanup then active.extraEffectsCleanup(); active.extraEffectsCleanup = nil end
    if active.blinkEffectsCleanup then active.blinkEffectsCleanup(); active.blinkEffectsCleanup = nil end
    if active.extra4EffectsCleanup then active.extra4EffectsCleanup(); active.extra4EffectsCleanup = nil end
    if active.electricStepCleanup then active.electricStepCleanup(); active.electricStepCleanup = nil end
    for ball, _ in pairs(active.balls) do
        if ball and ball.Parent then
            local mesh = ball:FindFirstChild("VisualMeshPart"); if mesh then mesh:Destroy() end
        end
    end
    active.balls = {}
    if active.handMesh then pcall(function() active.handMesh:Destroy() end); active.handMesh = nil end
    active.electricClones = {}
    if active.speedLoop then active.speedLoop:Disconnect(); active.speedLoop = nil end
    resetUIToDefault()
    tweenFOV(active.originalFOV,0.3)
end

