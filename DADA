local function setupAnimationReplacer(char)
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    hum.AnimationPlayed:Connect(function(track)
        local id = track.Animation.AnimationId
        local map = getCurrentAnimMap()
        local newId = map[id]
        if newId then
            track:Stop()
            local newAnim = Instance.new("Animation"); newAnim.AnimationId = newId
            local newTrack = hum:LoadAnimation(newAnim); newTrack:Play()
            if track.Length > 0 and newTrack.Length > 0 then newTrack:AdjustSpeed(newTrack.Length / track.Length) end
        end
        if tostring(id):find("140491244934559") then track.Animation.AnimationId = "rbxassetid://85012092465916" end
    end)
end

local function processBall(ball)
    if not ball then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local ballPart = ball:IsA("BasePart") and ball or ball:FindFirstChildWhichIsA("BasePart")
    if not ballPart then return end
    local dist = (ballPart.Position - hrp.Position).Magnitude
    if dist <= GARUDA_CONFIG.DetectionRadius then
        if not active.balls[ball] then
            active.balls[ball] = true
            forceHide(ball)
            attachMeshToPart(ball, GARUDA_CONFIG.MeshId, GARUDA_CONFIG.TextureId, GARUDA_CONFIG.Scale)
            updateFOVByStickVisibility()
        end
    end
end

local function startBallWatcher()
    local bullets = workspace:WaitForChild("Bullets",10)
    if not bullets then return end
    local function watchFolder(folder)
        for _, child in ipairs(folder:GetChildren()) do processBall(child) end
        folder.ChildAdded:Connect(processBall)
    end
    local ballFolder = bullets:FindFirstChild("Ball")
    if ballFolder then watchFolder(ballFolder) end
    bullets.ChildAdded:Connect(function(child) if child.Name == "Ball" then watchFolder(child) end end)
end

local function startVisibilityUpdater()
    if active.visibilityUpdater then return end
    active.visibilityUpdater = RunService.RenderStepped:Connect(function()
        if not active.fullModActive then return end
        if not active.handMesh or not active.handMesh.Parent then return end
        local hasBall = false
        for ball, _ in pairs(active.balls) do
            if ball and ball.Parent then
                hasBall = true
                forceHide(ball)
                attachMeshToPart(ball, GARUDA_CONFIG.MeshId, GARUDA_CONFIG.TextureId, GARUDA_CONFIG.Scale)
            else
                active.balls[ball] = nil
            end
        end
        local newTransparency = hasBall and 1 or 0
        if active.handMesh.Transparency ~= newTransparency then
            active.handMesh.Transparency = newTransparency
            updateGarudaByStick()
            updateFOVByStickVisibility()
        end
    end)
end

