local lastPassiveFrame = 0
RunService.Heartbeat:Connect(function()
    if isSkillActive or not Humanoid then return end
    lastPassiveFrame = lastPassiveFrame + 1
    if lastPassiveFrame % 3 ~= 0 then return end
    local animPlaying = false
    for _, track in ipairs(Humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(PASSIVE_ANIM_ID) then
            animPlaying = true
            local pos = track.TimePosition
            if pos >= 3.0 and pos <= 5.0 then
                track.TimePosition = 6.0
                pos = 6.0
                if aimActive then
                    aimActive = false
                    aimDisabled = true
                    lockedTarget = nil
                end
                if not soundPlayed then
                    soundPlayed = true
                    local burstSound = Instance.new("Sound", Root)
                    burstSound.SoundId = BURST_SOUND_ID
                    burstSound.Volume = 1
                    burstSound:Play()
                    Debris:AddItem(burstSound, 3)
                end
            end
            if pos >= 6.0 and pos < 8.0 then
                if not cachedEnergySource then
                    cachedEnergySource = ReplicatedStorage.Utils.MeiMei.BirdStrikeAOE.EnergyBurst
                end
                if lastPassiveFrame % 6 == 0 then
                    local arm = Character and Character:FindFirstChild("Right Arm")
                    if arm and cachedEnergySource then
                        local clone = cachedEnergySource:Clone()
                        local at = Instance.new("Attachment", arm)
                        at.Position = Vector3.new(0, -0.98, 0)
                        clone.Parent = at
                        local function applyB(obj)
                            if obj:IsA("ParticleEmitter") then
                                obj.Color = ColorSequence.new(Color3.fromRGB(120, 120, 255))
                                local kps = {}
                                for _, kp in ipairs(obj.Size.Keypoints) do
                                    table.insert(kps, NumberSequenceKeypoint.new(kp.Time, kp.Value * 0.15))
                                end
                                obj.Size = NumberSequence.new(kps)
                                obj.Enabled = true
                                obj:Emit(2)
                            end
                            for _, c in ipairs(obj:GetChildren()) do applyB(c) end
                        end
                        applyB(clone)
                        Debris:AddItem(at, 0.1)
                    end
                end
            end
            if pos >= 8.1 then
                Camera.FieldOfView = math.lerp(Camera.FieldOfView, 50, 0.15)
            else
                Camera.FieldOfView = math.lerp(Camera.FieldOfView, 60, 0.15)
            end
            break
        end
    end
    if not animPlaying and lastAnimWasPlaying then
        aimActive = false
        aimDisabled = false
        lockedTarget = nil
        soundPlayed = false
        TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FieldOfView = originalFOV}):Play()
    end
    lastAnimWasPlaying = animPlaying
end)

