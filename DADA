local OLD_PASSIVE_SOUND_ID = "99951577218359"
local NEW_PASSIVE_SOUND_ID = "104119789524388"

local function captureAndReplace(sound)
    if not sound then return end
    local soundId = tostring(sound.SoundId)
    if soundId:find(OLD_PASSIVE_SOUND_ID) then
        sound.SoundId = "rbxassetid://" .. NEW_PASSIVE_SOUND_ID
    end
end

local function watchForSounds(container)
    container.ChildAdded:Connect(function(child)
        if child:IsA("Sound") then
            captureAndReplace(child)
        else
            watchForSounds(child)
        end
    end)
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Sound") then
            captureAndReplace(child)
        else
            watchForSounds(child)
        end
    end
end
watchForSounds(workspace)

-- ========== ЗАМЕНА АНИМАЦИЙ (ГЛОБАЛЬНАЯ) ==========
local function replaceAnimation(track, humanoid)
    if not track or not track.Animation or not track.IsPlaying then return end
    local animId = tostring(track.Animation.AnimationId)
    for oldId, newId in pairs(ANIMATION_REPLACEMENTS) do
        if animId:find(oldId) then
            local currentTime = track.TimePosition
            local currentSpeed = track.Speed
            track:Stop()
            local newAnim = Instance.new("Animation")
            newAnim.AnimationId = "rbxassetid://" .. newId
            local newTrack = humanoid:LoadAnimation(newAnim)
            newTrack:Play()
            newTrack:AdjustSpeed(currentSpeed)
            newTrack.TimePosition = math.min(currentTime, newTrack.Length)
            newTrack.Priority = Enum.AnimationPriority.Action
            break
        end
    end
end

