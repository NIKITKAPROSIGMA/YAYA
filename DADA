local function setupBlinkEffects(char)
    if active.blinkEffectsCleanup then active.blinkEffectsCleanup(); active.blinkEffectsCleanup = nil end
    local usedTimings = {}; local activeConnection = nil; local currentLegFX = nil
    local RS = game:GetService("ReplicatedStorage")
    local RING_PATH = RS:WaitForChild("Utils").Itadori.CounterHit.Feint.Ring
    local ELEC_PATH = RS.Utils.Megumi.NueShock.Electric
    local function applyVisualAndSoundFixes(character)
        local fxFolder = workspace:FindFirstChild("Effects")
        local checkList = {character}; if fxFolder then table.insert(checkList, fxFolder) end
        for _, container in pairs(checkList) do
            for _, obj in pairs(container:GetDescendants()) do
                if obj:IsA("Sound") then
                    if obj.Name == "Swing" and obj.SoundId ~= BLINK_CONFIG.NewSwingId then obj.SoundId = BLINK_CONFIG.NewSwingId
                    elseif obj.Name == "Charge" and obj.SoundId == BLINK_CONFIG.TargetChargeId then obj.SoundId = BLINK_CONFIG.NewChargeId end
                end
                if obj.Name == "FullRisingRage" then
                    if obj:IsA("BasePart") then obj.Transparency = 1 end
                    for _, p in pairs(obj:GetDescendants()) do if p:IsA("ParticleEmitter") or p:IsA("Light") then p.Enabled = false end end
                elseif obj.Name == "MassChargeLeg" then
                    for _, p in pairs(obj:GetDescendants()) do if p:IsA("ParticleEmitter") then p.Color = ColorSequence.new(BLINK_CONFIG.ColorBlue); p.LightInfluence = 0 end end
                end
            end
        end
    end
    local function spawnLegEffect(character)
        local leg = character:FindFirstChild("Right Leg") or character:FindFirstChild("RightUpperLeg")
        if not leg then return end
        if currentLegFX then currentLegFX:Destroy() end
        local att = Instance.new("Attachment", leg); att.Name = "LegFX_Nue_Fixed"; currentLegFX = att
        local clone = ELEC_PATH:Clone()
        local function setup(obj)
            if obj:IsA("ParticleEmitter") then
                local kps = {}; for _, kp in ipairs(obj.Size.Keypoints) do table.insert(kps, NumberSequenceKeypoint.new(kp.Time, kp.Value * 0.2)) end
                obj.Size = NumberSequence.new(kps)
                obj.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, BLINK_CONFIG.ColorBlue), ColorSequenceKeypoint.new(0.5, BLINK_CONFIG.ColorPink), ColorSequenceKeypoint.new(1, BLINK_CONFIG.ColorBlue)})
                obj.LightInfluence = 0; obj.Brightness = 10; obj.ZOffset = 1; obj.Enabled = true; obj:Emit(120)
            end
            for _, c in ipairs(obj:GetChildren()) do setup(c) end
        end
        setup(clone); clone.Parent = att
    end
    local function attemptBlink(root)
        local oldPos = root.Position; local mPos = Mouse.Hit.Position
        local diff = Vector2.new(mPos.X, mPos.Z) - Vector2.new(oldPos.X, oldPos.Z)
        local dist = diff.Magnitude
        -- Проверка двойного тапа: если активен, то телепорт всегда, иначе только если дистанция >= TriggerDist
        if active.thunderKickDoubleTap then
            -- разрешаем телепорт всегда
        elseif dist < BLINK_CONFIG.TriggerDist then
            return false
        end
        local dir = Vector3.new(diff.X, 0, diff.Y).Unit
        local moveDist = math.min(dist, BLINK_CONFIG.MaxBlink)
        local params = RaycastParams.new(); params.FilterDescendantsInstances = {root.Parent}
        local ray = workspace:Raycast(oldPos, dir * moveDist, params)
        local finalPos = ray and (ray.Position - (dir * 1.5)) or (oldPos + (dir * moveDist))
        root.CFrame = CFrame.new(Vector3.new(finalPos.X, oldPos.Y, finalPos.Z), Vector3.new(finalPos.X + dir.X, oldPos.Y, finalPos.Z + dir.Z))
        local s = Instance.new("Sound", root); s.SoundId = BLINK_CONFIG.BlinkSoundId; s.Volume = 2; s:Play(); Debris:AddItem(s,2)
        local att = Instance.new("Attachment", root)
        local r = RING_PATH:Clone(); r.Parent = att
        local e = ELEC_PATH:Clone(); e.Parent = att
        for _, v in pairs(att:GetDescendants()) do
            if v:IsA("ParticleEmitter") then v.LightInfluence = 0; v.LockedToPart = true; v.Color = ColorSequence.new(BLINK_CONFIG.ColorBlue); v:Emit(30); task.delay(BLINK_CONFIG.EffectDuration, function() v.Enabled = false end) end
        end
        Debris:AddItem(att,1.2)
    end
    local function startSkill(character)
        local hum = character:FindFirstChild("Humanoid"); local root = character:FindFirstChild("HumanoidRootPart")
        if not hum or not root or activeConnection then return end
        local track = nil
        for _, t in pairs(hum:GetPlayingAnimationTracks()) do if t.Animation.AnimationId:find(BLINK_CONFIG.AnimId) then track = t; break end end
        if not track then return end
        active.skillActive = true
        tweenFOV(110, 0.5)
        local legSpawned = false
        activeConnection = RunService.RenderStepped:Connect(function()
            if track.IsPlaying then
                local tPos = track.TimePosition
                local camDir = (Camera.CFrame.LookVector * Vector3.new(1,0,1)).Unit
                root.AssemblyLinearVelocity = Vector3.new(camDir.X * BLINK_CONFIG.PushSpeed, root.AssemblyLinearVelocity.Y, camDir.Z * BLINK_CONFIG.PushSpeed)
                applyVisualAndSoundFixes(character)
                for _, t in pairs(BLINK_CONFIG.TeleportTimings) do
                    if tPos >= t and not usedTimings[t] then usedTimings[t] = true; attemptBlink(root) end
                end
                if tPos >= BLINK_CONFIG.LegFxStart and tPos <= BLINK_CONFIG.LegFxEnd then
                    if not legSpawned then legSpawned = true; spawnLegEffect(character) end
                    if Camera.FieldOfView ~= 60 then tweenFOV(60, 0.3) end
                else
                    if currentLegFX then currentLegFX:Destroy(); currentLegFX = nil; legSpawned = false end
                    if Camera.FieldOfView ~= 110 then tweenFOV(110, 0.3) end
                end
            else
                active.skillActive = false
                updateFOVByStickVisibility()
                if currentLegFX then currentLegFX:Destroy(); currentLegFX = nil end
                usedTimings = {}; activeConnection:Disconnect(); activeConnection = nil
                -- сбрасываем флаг двойного тапа после использования скилла
                active.thunderKickDoubleTap = false
            end
        end)
    end
    local heartbeatCheckConn = RunService.Heartbeat:Connect(function()
        if char and not activeConnection then
            local hum = char:FindFirstChild("Humanoid")
            if hum then for _, t in pairs(hum:GetPlayingAnimationTracks()) do if t.Animation.AnimationId:find(BLINK_CONFIG.AnimId) then startSkill(char); break end end end
        end
    end)
    active.blinkEffectsCleanup = function()
        if activeConnection then activeConnection:Disconnect(); activeConnection = nil end
        if heartbeatCheckConn then heartbeatCheckConn:Disconnect() end
        if currentLegFX then currentLegFX:Destroy(); currentLegFX = nil end
        active.skillActive = false
        updateFOVByStickVisibility()
        usedTimings = {}
        active.thunderKickDoubleTap = false
    end
end

