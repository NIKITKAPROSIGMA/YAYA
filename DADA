local function createTrailPhantom()
    if not Character then return end
    local model = Instance.new("Model", workspace)
    local partsList = {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
    local parts = {}
    for _, name in ipairs(partsList) do
        local original = Character:FindFirstChild(name)
        if original and original:IsA("BasePart") then
            local clone = original:Clone()
            clone:ClearAllChildren()
            clone.CanCollide = false
            clone.Anchored = true
            clone.Material = Enum.Material.SmoothPlastic
            clone.Color = Color3.fromRGB(120, 120, 255)
            clone.Transparency = 0.6
            clone.CFrame = original.CFrame
            clone.Parent = model
            table.insert(parts, clone)
        end
    end
    task.spawn(function()
        for _, part in ipairs(parts) do
            TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {Transparency = 1}):Play()
        end
        task.wait(0.5)
        model:Destroy()
    end)
end

