-- === Z СКИЛЛ ==========
local function runZSkill()
    -- Проверка: есть ли нужные скиллы
    if not hasRequiredSkill() then return end
    if tick() - lastZUse < Z_COOLDOWN then return end
    if isSkillActive then return end
    if not checkZStrict() then return end

    lastZUse = tick()
    isSkillActive = true
    aimDisabled = false
    aimActive = false
    lockedTarget = nil
    if skillObj then skillObj:SetAttribute("LastUse", tick()) end

    smallActivationEffect()
    -- Запускаем вспомогательную анимацию (она не прерывает скилл)
    local secondaryTrack = startSecondaryAnim()

    local originalSpeed = Humanoid.WalkSpeed
    local startTime = tick()

    globalCC.Enabled = true
    globalCC.TintColor = Color3.fromRGB(200, 200, 255)
    globalCC.Saturation = 1.1
    local s = Instance.new("Sound", Root)
    s.SoundId = SOUND_ID
    s:Play()
    Debris:AddItem(s, 3)
    Camera.FieldOfView = 100

    if not cachedDustSource then
        cachedDustSource = ReplicatedStorage.Utils.Gojo.Teleport.Floor.Dust
    end

    local lastPhantomTime = 0
    local lastWindTime = 0

    while isSkillActive and tick() - startTime < SKILL_DURATION do
        if not Character or not Humanoid or not Root then break end
        if not checkZStrict() or Root.Velocity.Magnitude < 8 then break end

        Humanoid.WalkSpeed = 50
        if Camera.FieldOfView ~= 100 then Camera.FieldOfView = 100 end

        if tick() - lastPhantomTime >= 0.1 then
            createTrailPhantom()
            lastPhantomTime = tick()
        end

        if tick() - lastWindTime >= 0.15 then
            local torso = Character:FindFirstChild("Torso")
            if torso and cachedDustSource then
                local clone = cachedDustSource:Clone()
                local at = Instance.new("Attachment", torso)
                clone.Parent = at
                local function activate(obj)
                    if obj:IsA("ParticleEmitter") then
                        obj.Enabled = true
                        obj:Emit(2)
                    end
                    for _, child in ipairs(obj:GetChildren()) do activate(child) end
                end
                activate(clone)
                Debris:AddItem(at, 0.2)
            end
            lastWindTime = tick()
        end

        task.wait()
    end

    lastSkillEndTime = tick()
    isSkillActive = false
    if secondaryTrack and secondaryTrack.IsPlaying then secondaryTrack:Stop() end

    TweenService:Create(Camera, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FieldOfView = originalFOV}):Play()
    TweenService:Create(globalCC, TweenInfo.new(0.5), {Saturation = 0, TintColor = Color3.fromRGB(255,255,255)}):Play()
    task.delay(0.6, function() globalCC.Enabled = false end)

    if Humanoid then
        Humanoid.WalkSpeed = originalSpeed
    end
end

