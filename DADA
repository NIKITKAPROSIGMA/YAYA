local function checkZStrict()
    if not Humanoid then return false end
    local tracks = Humanoid:GetPlayingAnimationTracks()
    local mainFound = false
    for _, track in ipairs(tracks) do
        local id = tostring(track.Animation.AnimationId)
        if id:find(TARGET_ANIM_ID) or id:find(NEW_TARGET_ANIM_ID) then
            mainFound = true
        elseif track.Priority == Enum.AnimationPriority.Action or track.Priority == Enum.AnimationPriority.Action2 then
            return false
        end
    end
    return mainFound
end

