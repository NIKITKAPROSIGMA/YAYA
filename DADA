local function startUltAction()
    if active.ultActive then return end
    fullCleanupUlt()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    local info = char:FindFirstChild("Info")
    local elements = {tags = {}, effects = {}}
    local animTrack = nil
    if hum then
        local anim = Instance.new("Animation"); anim.AnimationId = ULT_CONFIG.AnimId
        animTrack = hum:LoadAnimation(anim); animTrack:Play()
    end
    if info then
        for _, name in ipairs({"inSkill", "Stun"}) do
            local tag = Instance.new("BoolValue"); tag.Name = name; tag.Value = true; tag.Parent = info
            table.insert(elements.tags, tag)
        end
    end
    local baseEffect = getObject(ULT_CONFIG.EffectPath)
    if baseEffect and root then
        for i = 1, 3 do
            local clone = baseEffect:Clone()
            setupParticles(clone, ULT_CONFIG.EffectColor, ULT_CONFIG.EffectRate, nil, nil)
            local att = Instance.new("Attachment", root); clone.Parent = att
            table.insert(elements.effects, att); table.insert(elements.effects, clone)
        end
    end
    active.currentCleanup = function()
        if animTrack then pcall(function() animTrack:Stop(); animTrack:Destroy() end) end
        for _, obj in ipairs(elements.tags) do pcall(function() obj:Destroy() end) end
        for _, obj in ipairs(elements.effects) do pcall(function() obj:Destroy() end) end
    end
    active.ultActive = true
end

local function handleSound(sound)
    if not sound or not sound:IsA("Sound") then return end
    local id = sound.SoundId
    if not id or id == "" then return end
    local char = LocalPlayer.Character
    if not char then return end
    local isOur = sound:IsDescendantOf(char) or (sound.Parent and sound.Parent:IsDescendantOf(char)) or
                  (sound.Parent and sound.Parent.Name == "Effects" and workspace.Effects and sound:IsDescendantOf(workspace.Effects))
    if not isOur then return end
    if id:find(SWING.Original) then
        sound.SoundId = "rbxassetid://" .. SWING.New; sound.Volume = SWING.Volume; return
    end
    if id:find(FIST.Original) then
        if active.handMesh and active.handMesh.Transparency == 0 then
            sound.SoundId = "rbxassetid://" .. FIST.New; sound.Volume = FIST.Volume
        end; return
    end
    local numId = string.match(id, "%d+")
    local repl = ULT_CONFIG.SoundReplace[numId]
    if repl then
        sound.Volume = 0
        local proxy = Instance.new("Sound", sound.Parent); proxy.SoundId = "rbxassetid://" .. repl; proxy.Volume = 1; proxy:Play(); Debris:AddItem(proxy,10)
        if repl == "135895192563038" then
            startUltAction(); proxy.Ended:Connect(fullCleanupUlt)
        elseif repl == "98084023171542" or repl == "87517557827169" then
            fullCleanupUlt()
        end
    end
end

local function setupIdleBlock(char)
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChild("Animator")
    if not animator then return end
    local info = char:FindFirstChild("Info")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local function createTrack(id, prio)
        local a = Instance.new("Animation"); a.AnimationId = id
        local t = animator:LoadAnimation(a); t.Priority = prio; return t
    end
    local idleTrack = createTrack(IDLE_CONFIG.IdleAnim, Enum.AnimationPriority.Action4)
    local blockTrack = createTrack(IDLE_CONFIG.BlockAnim, Enum.AnimationPriority.Action4)
    blockTrack.Looped = true
    local isIdle = false; local isBlock = false; local idleTimer = 0
    RunService.RenderStepped:Connect(function(dt)
        if not char.Parent or not hum.Parent then return end
        local vel = root.AssemblyLinearVelocity
        local speed = (Vector3.new(vel.X,0,vel.Z)).Magnitude
        if info and info:FindFirstChild("Block") then
            idleTimer = 0
            if isIdle then idleTrack:Stop(0.1); isIdle = false end
            if not isBlock then blockTrack:Play(0.15); isBlock = true end
        else
            if isBlock then blockTrack:Stop(0.2); isBlock = false end
            local moving = speed > 0.8 or (info and (info:FindFirstChild("Stun") or info:FindFirstChild("InSkill") or info:FindFirstChild("KnockBack")))
            if not moving then
                idleTimer = idleTimer + dt
                if idleTimer >= IDLE_CONFIG.Delay then
                    if not isIdle then
                        for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
                            if t ~= blockTrack and t.Priority.Value < Enum.AnimationPriority.Action4.Value then t:Stop(0.1) end
                        end
                        idleTrack:Play(0.1)
                        idleTrack.TimePosition = IDLE_CONFIG.TargetTime
                        idleTrack:AdjustSpeed(0)
                        isIdle = true
                    end
                    idleTrack.TimePosition = IDLE_CONFIG.TargetTime
                end
            else
                idleTimer = 0
                if isIdle then idleTrack:Stop(0.1); isIdle = false end
            end
        end
    end)
end

