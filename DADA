RunService.Heartbeat:Connect(function()
    local char = Character
    local hum = char and char:FindFirstChild("Humanoid")
    if not hum then return end
    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(PASSIVE_ANIM_ID) then
            local currentPos = track.TimePosition
            local now = tick()
            local zWasActive = (now - lastZUse) <= 0.1 or (now - lastSkillEndTime) <= 0.1 or isSkillActive
            if zWasActive and not aimDisabled then
                if currentPos < 6.0 or currentPos > 6.5 then
                    if not aimActive and not lockedTarget then
                        lockedTarget = GetClosestPlayerToCursor()
                        if lockedTarget then aimActive = true end
                    end
                else
                    if aimActive then
                        aimActive = false
                        aimDisabled = true
                        lockedTarget = nil
                    end
                end
            end
            break
        end
    end
end)

