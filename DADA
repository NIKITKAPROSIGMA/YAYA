local function getObject(path)
    local obj = game
    for part in path:gsub("%.", "/"):gmatch("([^/]+)") do
        obj = obj and obj:FindFirstChild(part)
        if not obj then break end
    end
    return obj
end

local function setupParticles(obj, color, rate, sizeMult, speedMult)
    if obj:IsA("ParticleEmitter") then
        obj.Color = ColorSequence.new(color)
        obj.LightEmission = 1
        obj.Brightness = 10
        obj.ZOffset = 1.5
        obj.Rate = rate
        if sizeMult then
            local seq = obj.Size
            if seq and #seq.Keypoints > 0 then
                obj.Size = NumberSequence.new(seq.Keypoints[1].Value * sizeMult)
            end
        end
        if speedMult then
            obj.Speed = NumberRange.new(obj.Speed.Min * speedMult, obj.Speed.Max * speedMult)
        end
        obj.Enabled = true
    end
    for _, child in ipairs(obj:GetChildren()) do setupParticles(child, color, rate, sizeMult, speedMult) end
end

local function findGarudaInCharacter(char)
    if not char then return nil end
    local setAssets = char:FindFirstChild("SetAssets")
    if setAssets then
        local garuda = setAssets:FindFirstChild("Garuda")
        if garuda then return garuda end
    end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj.Name == "Garuda" and obj:IsA("Model") then return obj end
    end
    return nil
end

local function forceHide(obj)
    if not obj or not obj.Parent then return end
    for _, v in ipairs(obj:GetDescendants()) do
        if v and (v.Name == "VisualMeshPart" or v.Name == "HandCustomMesh") then continue end
        if v:IsA("BasePart") then v.Transparency = 1
        elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") then v.Enabled = false end
    end
    if obj:IsA("BasePart") then obj.Transparency = 1 end
end

local function attachMeshToPart(target, meshId, textureId, scale)
    local partForMesh = target:IsA("BasePart") and target or target:FindFirstChildWhichIsA("BasePart")
    if not partForMesh or partForMesh:FindFirstChild("VisualMeshPart") then return end
    local part = Instance.new("Part")
    part.Name = "VisualMeshPart"
    part.Parent = partForMesh
    part.CanCollide = false
    part.Massless = true
    part.Size = Vector3.new(1,1,1)
    part.Transparency = 0
    local mesh = Instance.new("SpecialMesh", part)
    mesh.MeshId = meshId
    mesh.TextureId = textureId
    mesh.Scale = scale
    local weld = Instance.new("Weld", part)
    weld.Part0 = partForMesh
    weld.Part1 = part
    weld.C0 = CFrame.new(0,0,0)
end

local function setupCombatTrail(obj, weld, char)
    local rightArm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand")
    if not rightArm then return false end
    weld.Part0 = rightArm
    weld.C1 = CFrame.new(0,0,0)
    local isHandVisible = active.handMesh and active.handMesh.Transparency == 0
    if not isHandVisible then
        weld.C0 = CFrame.new(0,0,0)
        obj.Size = Vector3.new(1.1,2.2,1.1)
        obj.Transparency = 0.7
    else
        local posOffset = CFrame.new(0,-1,-3)
        local rotOffset = CFrame.Angles(math.rad(90),0,0)
        weld.C0 = posOffset * rotOffset
        obj.Size = Vector3.new(0.6,1.2,0.6)
        obj.Transparency = 0.5
    end
    obj.Color = Color3.fromRGB(232, 40, 231) -- изменено
    obj.Material = Enum.Material.Neon
    obj.CanCollide = false
    local trail = obj:FindFirstChildOfClass("Trail")
    if trail then trail.Color = ColorSequence.new(Color3.fromRGB(232, 40, 231)); trail.WidthScale = NumberSequence.new(1); trail.Enabled = true end
    return true
end

local function onCombatTrailAdded(obj)
    if obj.Name ~= "CombatTrail" then return end
    task.spawn(function()
        local weld = obj:FindFirstChild("Weld")
        if not weld then weld = obj:WaitForChild("Weld",0.2) end
        if not weld then return end
        local char = LocalPlayer.Character
        if not char then return end
        if not weld.Part0 or not weld.Part0:IsDescendantOf(char) then return end
        setupCombatTrail(obj, weld, char)
    end)
end

local function tweenFOV(target, speed)
    TweenService:Create(Camera, TweenInfo.new(speed or 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {FieldOfView = target}):Play()
end

local function updateFOVByStickVisibility()
    if not active.fullModActive then return end
    if active.skillActive or active.fovForced then return end
    local isVisible = active.handMesh and active.handMesh.Transparency == 0
    if isVisible then
        if Camera.FieldOfView ~= active.originalFOV then tweenFOV(active.originalFOV, 0.4) end
    else
        if Camera.FieldOfView ~= 110 then tweenFOV(110, 0.4) end
    end
end

local function createGarudaElectric()
    local char = LocalPlayer.Character
    if not char then return {} end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    local base = getObject(ELECTRIC_GARUDA.Path)
    if not base then return {} end
    local clones = {}
    for i = 1, ELECTRIC_GARUDA.Copies do
        local clone = base:Clone()
        setupParticles(clone, ELECTRIC_GARUDA.Color, ELECTRIC_GARUDA.Rate, ELECTRIC_GARUDA.SizeMult, ELECTRIC_GARUDA.SpeedMult)
        local att = Instance.new("Attachment", root)
        att.CFrame = CFrame.new(ELECTRIC_GARUDA.Offset) * CFrame.Angles(math.rad(ELECTRIC_GARUDA.Rotation.X), math.rad(ELECTRIC_GARUDA.Rotation.Y), math.rad(ELECTRIC_GARUDA.Rotation.Z))
        clone.Parent = att
        table.insert(clones, {clone = clone, att = att})
    end
    return clones
end

local function destroyGarudaElectric()
    for _, entry in ipairs(active.electricClones) do
        pcall(function() if entry.att then entry.att:Destroy() end; if entry.clone then entry.clone:Destroy() end end)
    end
    active.electricClones = {}
end

local function getTargetSpeed(char)
    local info = char:FindFirstChild("Info")
    if not info then return GARUDA_CONFIG.BaseSpeed + GARUDA_CONFIG.BuffAmount end
    for _, flag in ipairs(GARUDA_CONFIG.StopFlags) do
        if info:FindFirstChild(flag) then return nil end
    end
    return GARUDA_CONFIG.BaseSpeed + GARUDA_CONFIG.BuffAmount
end

local function startSpeedBuff(char)
    if active.speedLoop then active.speedLoop:Disconnect() end
    active.speedLoop = RunService.RenderStepped:Connect(function()
        if not active.garudaActive then return end
        if not char or not char.Parent then if active.speedLoop then active.speedLoop:Disconnect() end return end
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hum then
            local target = getTargetSpeed(char)
            if target and hum.WalkSpeed ~= target then hum.WalkSpeed = target end
        end
    end)
end

local function stopSpeedBuff()
    if active.speedLoop then active.speedLoop:Disconnect(); active.speedLoop = nil end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hum and hum.WalkSpeed == GARUDA_CONFIG.BaseSpeed + GARUDA_CONFIG.BuffAmount then hum.WalkSpeed = GARUDA_CONFIG.BaseSpeed end
    end
end

