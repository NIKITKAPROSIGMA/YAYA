local ALLOWED_MOVES = {
    ["Cursory Impact"] = true,
    ["Time Cell Moon Palace"] = true
}

local function hasRequiredSkill()
    local char = Character
    if not char then return false end
    local moveset = char:FindFirstChild("Moveset")
    if not moveset then
        local playerName = LocalPlayer.Name
        local characters = workspace:FindFirstChild("Characters")
        if characters then
            local playerChar = characters:FindFirstChild(playerName)
            if playerChar then
                moveset = playerChar:FindFirstChild("Moveset")
            end
        end
    end
    if not moveset then return false end
    for _, move in ipairs(moveset:GetChildren()) do
        if ALLOWED_MOVES[move.Name] then
            return true
        end
    end
    return false
end

