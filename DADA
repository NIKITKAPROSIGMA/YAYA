-- ========== ФУНКЦИЯ ПОИСКА ЦЕЛИ ==========
local function GetClosestPlayerToCursor()
    local closest = nil
    local shortestDist = AIM_RADIUS_SCREEN + 1
    local cursorPos = UserInputService:GetMouseLocation()
    local char = Character
    local myRoot = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    if not myRoot then return nil end

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local hum = v.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local part = v.Character:FindFirstChild("HumanoidRootPart") or v.Character:FindFirstChild("Torso")
                if part then
                    local worldDist = (myRoot.Position - part.Position).Magnitude
                    if worldDist <= AIM_RADIUS_WORLD then
                        local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local distToCursor = (Vector2.new(pos.X, pos.Y) - cursorPos).Magnitude
                            if distToCursor < shortestDist then
                                closest = part
                                shortestDist = distToCursor
                            end
                        end
                    end
                end
            end
        end
    end

    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= Character then
            local hum = obj:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local part = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                if part then
                    local worldDist = (myRoot.Position - part.Position).Magnitude
                    if worldDist <= AIM_RADIUS_WORLD then
                        local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local distToCursor = (Vector2.new(pos.X, pos.Y) - cursorPos).Magnitude
                            if distToCursor < shortestDist then
                                closest = part
                                shortestDist = distToCursor
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

